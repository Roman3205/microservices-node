generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Post {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  user_id String
  title String
  content String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user_id])
}